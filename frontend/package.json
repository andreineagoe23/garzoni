  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite",
    "start": "pnpm run dev",
    "clean:cache": "node -e \"try{require('fs').rmSync('node_modules/.vite',{recursive:true,force:true});console.log('Vite cache cleared.');}catch(e){console.log(e.message);process.exit(1);}\"",
    "clean": "node -e \"const fs=require('fs');const p=require('path');try{fs.rmSync('dist',{recursive:true,force:true});console.log('Removed dist');}catch(e){};console.log('Clean done.');\"",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "npx --yes prettier --write .",
    "format:check": "npx --yes prettier --check .",
    "build": "tsc --noEmit && vite build",
    "build:analyze": "cross-env ANALYZE=true tsc --noEmit && cross-env ANALYZE=true vite build",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prop-types": "^15.7.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gh-pages": "^6.2.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-imagetools": "7.0.5",
    "vitest": "^3.0.5"
  }
