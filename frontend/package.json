{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@amplitude/analytics-browser": "^2.33.5",
    "@ckeditor/ckeditor5-build-classic": "41.4.2",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-query": "^5.59.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "axios": "^1.7.9",
    "canvas-confetti": "^1.9.4",
    "classnames": "^2.5.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.0.6",
    "html2canvas": "^1.4.1",
    "i18next": "^23.16.0",
    "js-cookie": "^3.0.5",
    "js-cookies": "^1.0.4",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-bootstrap-icons": "^1.11.5",
    "react-calendar-heatmap": "^1.10.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-google-recaptcha-v3": "^1.10.1",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^7.1.0",
    "react-slick": "^0.30.3",
    "react-vertical-timeline-component": "^3.5.3",
    "recharts": "^2.15.3",
    "sass": "^1.97.3",
    "three": "^0.182.0",
    "web-vitals": "^4.2.4",
    "yahoo-finance2": "^2.13.3",
    "zustand": "^4.5.5"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 craco start",
    "clean:cache": "node -e \"try{require('fs').rmSync('node_modules/.cache',{recursive:true,force:true});console.log('Cache cleared. Run npm start.');}catch(e){console.log('Stop the dev server first, then run: npm run clean:cache');process.exit(1);}\"",
    "clean": "node -e \"const fs=require('fs');const p=require('path');['.cache','build'].forEach(d=>{const dir=p.join('node_modules',d);try{fs.rmSync(dir,{recursive:true,force:true});console.log('Removed',dir);}catch(e){}});try{fs.rmSync('build',{recursive:true,force:true});console.log('Removed build');}catch(e){};console.log('Clean done. Restart dev server and hard-refresh the browser (Ctrl+Shift+R).');\"",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "format:check": "npx --yes prettier --check .",
    "build": "craco build",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "craco test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "jest": {
    "moduleNameMapper": {
      "^contexts/(.*)$": "<rootDir>/src/contexts/$1",
      "^components/(.*)$": "<rootDir>/src/components/$1",
      "^services/(.*)$": "<rootDir>/src/services/$1",
      "^constants/(.*)$": "<rootDir>/src/constants/$1",
      "^utils/(.*)$": "<rootDir>/src/utils/$1",
      "^lib/(.*)$": "<rootDir>/src/lib/$1",
      "^types/(.*)$": "<rootDir>/src/types/$1",
      "^assets/(.*)$": "<rootDir>/src/assets/$1",
      "^hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^stores/(.*)$": "<rootDir>/src/stores/$1",
      "^react-router-dom$": "<rootDir>/src/test-utils/react-router-dom-mock.tsx",
      "^axios$": "<rootDir>/src/test-utils/axios-mock.ts"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@craco/craco": "^7.1.0",
    "@types/node": "22.8.7",
    "@types/react": "18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gh-pages": "^6.2.0",
    "postcss": "^8.5.6",
    "react-refresh": "^0.11.0",
    "react-scripts": "^5.0.1",
    "tailwindcss": "^3.4.14",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "4.9.5"
  }
}
