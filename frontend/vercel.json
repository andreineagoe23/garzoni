{
  "installCommand": "cd .. && corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "cd .. && pnpm --filter @garzoni/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://garzoni-production.up.railway.app/api"
    },
    {
      "source": "/api/:path*/",
      "destination": "https://garzoni-production.up.railway.app/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://garzoni-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
