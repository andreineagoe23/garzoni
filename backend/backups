INSERT INTO `core_course` VALUES (2,'Introduction to Budgeting','Learn the fundamentals of budgeting, including how to create and manage a budget, set financial goals, and track expenses. This course is perfect for anyone looking to gain control over their finances and start building good financial habits.',1,'course_images/IntroductionBudgeting.png','basic',1,0),(3,'Understanding Credit','This course covers everything you need to know about credit, including how it works, how to build it, and how to manage it responsibly to improve your financial standing.',1,'course_images/UnderstandingCredit.png','basic',1,0),(4,'Basic Investment Strategies','Learn the basics of investing, how to start building your investment portfolio, and how to manage risk to grow your wealth over time.',1,'course_images/BasicInvestment.png','basic',1,0),(5,'Real Estate Basics','Learn the foundational principles of real estate investing, including how to evaluate properties and make sound investment decisions.',2,'course_images/RealEstateBasics.png','basic',1,0),(6,'Market Research and Analysis','Master the skills needed to research and analyze real estate markets, so you can make data-driven decisions when investing.',2,'course_images/MarketResearch.png','basic',1,0),(7,'Advanced Real Estate Strategies','Take your real estate investment knowledge to the next level with advanced strategies that can help you scale your portfolio.',2,'course_images/AdvancedRealEstate.png','basic',1,0),(8,'Introduction to Cryptocurrency','Understand the basics of cryptocurrency, how it works, and why it???s changing the financial world.',3,'course_images/CryptoIntro.png','basic',1,0),(9,'Buying, Selling and Storing Crypto','Learn how to buy, sell, and securely store cryptocurrency to get started in the crypto market.',3,'course_images/BSSCrypto.png','basic',1,0),(10,'Advanced Cryptocurrency Concepts','Delve into advanced concepts in crypto, including DeFi, NFTs, and emerging trends that are shaping the future of digital finance.',3,'course_images/AdvancedCrypto.png','basic',1,0),(11,'Introduction to Forex Trading','Discover the fundamentals of forex trading, including currency pairs, market participants, and trading terminology.',4,'course_images/IntroductionForex.png','basic',1,0),(12,'Fundamentals of Forex Trading Strategies','Learn foundational trading strategies, technical indicators, and how to analyze forex charts effectively.',4,'course_images/FundamentalsForex.png','basic',1,0),(13,'Risk Management in Forex','Dive into essential risk management techniques to help safeguard your investments and maximize your trading potential.',4,'course_images/RiskForex.png','basic',1,0),(14,'Budgeting Beyond Basics','Dive deeper into advanced budgeting techniques to optimize your finances.',5,'course_images/BudgetBasics.png','basic',1,0),(15,'Smart Spending','Develop a mindful approach to spending that aligns with your values and goals.',5,'course_images/SmartSpending.png','basic',1,0),(16,'Maximizing Savings','Go beyond the basics and learn advanced saving techniques to boost your financial security.',5,'course_images/MaximizingSavings.png','basic',1,0),(17,'Building Wealth','Focus on strategies to grow your wealth steadily and sustainably.',5,'course_images/BuildingWealth.png','basic',1,0),(18,'Building a Positive Money Mindset','Learn how to develop a healthy relationship with money for long-term success.',6,'course_images/BuildingMindset.png','basic',1,0),(19,'Cultivating Financial Discipline','Master the art of self-discipline to achieve your financial goals.',6,'course_images/CultivatingDiscipline.png','basic',1,0),(20,'Resilience in Financial Setbacks','Learn to navigate and recover from financial challenges with confidence.',6,'course_images/FinancialSetbacks.png','basic',1,0),(21,'Financial Growth Mindset','Cultivate the mindset to continuously grow and improve your financial situation.',6,'course_images/FinancialGrowthMindset.png','basic',1,0);
