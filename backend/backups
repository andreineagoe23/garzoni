INSERT INTO `core_faq` VALUES (1,'Account & Profile','How do I reset my password?','Go to the login screen and click \'Forgot Password.\' You\'ll receive an email with a reset link.',1,0,0,'2025-12-07 17:22:52.386697'),(2,'Account & Profile','How do I change my email or username?','You can update your profile details from the Settings page.',1,1,0,'2025-12-07 17:22:52.391880'),(3,'Account & Profile','Can I delete my Monevo account?','Yes. Go to Settings → Danger Zone and click \'Delete My Account.\' This action is permanent.',1,1,0,'2025-12-07 17:22:52.396198'),(4,'Courses & Learning Paths','Are all courses free?','Most are free. Some premium paths (like personalized recommendations) require a subscription.',1,0,0,'2025-12-07 17:22:52.400015'),(5,'Courses & Learning Paths','How are learning paths structured?','Each path contains courses, and each course contains lessons with exercises, videos, or quizzes.',1,0,0,'2025-12-07 17:22:52.404615'),(6,'Courses & Learning Paths','How do I know which path is best for me?','Complete our questionnaire, and we\'ll recommend a personalized learning path.',1,0,0,'2025-12-07 17:22:52.408579'),(7,'Courses & Learning Paths','Can I switch paths later?','Yes. You can explore and switch between paths anytime from the All Topics page.',1,0,0,'2025-12-07 17:22:52.413261'),(8,'Points & Rewards','How do I earn points?','You earn points by completing lessons, quizzes, missions, and saving virtually.',1,0,0,'2025-12-07 17:22:52.418078'),(9,'Points & Rewards','What can I do with points?','Use them to unlock rewards, donate to causes, or show progress in your profile.',1,0,0,'2025-12-07 17:22:52.423154'),(10,'Points & Rewards','Do points expire?','No, your points remain valid as long as your account is active.',1,0,0,'2025-12-07 17:22:52.427653'),(11,'Technical Issues','The chatbot isn\'t responding. What should I do?','Try refreshing the page. If the issue persists, contact support at the bottom of this page.',1,0,0,'2025-12-07 17:22:52.431369'),(12,'Technical Issues','I completed a lesson, but it\'s not marked as done.','Make sure you\'ve completed all sections. If it\'s still not updating, refresh or log out/in.',1,0,0,'2025-12-07 17:22:52.435731'),(13,'Billing & Subscriptions','What do I get with a paid subscription?','Access to personalized learning paths, exclusive missions, and early features.',1,0,0,'2025-12-07 17:22:52.440328'),(14,'Billing & Subscriptions','How do I cancel my subscription?','Subscriptions can be managed via your Stripe account or by contacting support.',1,0,0,'2025-12-07 17:22:52.444844'),(15,'Billing & Subscriptions','Do you offer refunds?','Refunds are handled on a case-by-case basis. Contact support with your account and payment details.',1,0,0,'2025-12-07 17:22:52.449941');
