INSERT INTO `core_quiz` VALUES (4,11,'Introduction to Forex Trading','What is the primary goal of Forex Trading ?','[{\"id\": 1, \"text\": \"To buy and hold currencies for long-term investment\"}, {\"id\": 2, \"text\": \"To profit from short-term price movements in the exchange rate\"}, {\"id\": 3, \"text\": \"To exchange currencies for travel purposes\"}, {\"id\": 4, \"text\": \"To manage international financial risks\"}]','To profit from short-term price movements in the exchange rate'),(5,12,'Fundamentals of Forex trading Strategies','What does \'technical analysis\' focus on in Forex trading?','[{\"id\": 1, \"text\": \"The study of interest rate changes\"}, {\"id\": 2, \"text\": \"The study of past market data, primarily price and volume\"}, {\"id\": 3, \"text\": \"The analysis of a country\'s economic health\"}, {\"id\": 4, \"text\": \"The prediction of global political events\"}]','The study of past market data, primarily price and volume'),(6,13,'Risk Management in Forex','What is the purpose of setting a stop loss order in Forex trading?','[{\"id\": 1, \"text\": \"To lock in profits when the market moves in your favor\"}, {\"id\": 2, \"text\": \"To limit losses if the market moves against you\"}, {\"id\": 3, \"text\": \"To trade at a fixed exchange rate\"}, {\"id\": 4, \"text\": \"To exchange a currency at a specific time\"}]','To limit losses if the market moves against you'),(7,6,'Market research and Analysis','What is \'market segmentation\' in marketing research?','[{\"id\": 1, \"text\": \"The process of dividing a market into distinct groups of potential consumers\"}, {\"id\": 2, \"text\": \"The analysis of competitors in a specific market\"}, {\"id\": 3, \"text\": \"The act of launching a product in multiple markets\"}, {\"id\": 4, \"text\": \"The study of economic factors affecting a market\"}]','The process of dividing a market into distinct groups of potential consumers'),(8,21,'Understanding the Financial Growth Mindset','What is a key characteristic of a financial growth mindset?','[{\"id\": 1, \"text\": \"Believing that financial success is purely based on luck\"}, {\"id\": 2, \"text\": \"Understanding that financial skills can be developed over time\"}, {\"id\": 3, \"text\": \"Avoiding risks at all costs\"}, {\"id\": 4, \"text\": \"Only focusing on short-term gains\"}]','Understanding that financial skills can be developed over time'),(9,20,'Overcoming Financial Setbacks','What is the most effective first step when facing a financial setback?','[{\"id\": 1, \"text\": \"Ignoring the problem and hoping it resolves itself\"}, {\"id\": 2, \"text\": \"Blaming external factors for the situation\"}, {\"id\": 3, \"text\": \"Assessing the situation and creating an action plan\"}, {\"id\": 4, \"text\": \"Taking out more loans to cover the losses\"}]','Assessing the situation and creating an action plan'),(10,19,'Practicing Financial Discipline','Which habit best demonstrates financial discipline?','[{\"id\": 1, \"text\": \"Spending money freely without a budget\"}, {\"id\": 2, \"text\": \"Saving and investing consistently, even in small amounts\"}, {\"id\": 3, \"text\": \"Relying on credit cards to cover daily expenses\"}, {\"id\": 4, \"text\": \"Making impulsive financial decisions\"}]','Saving and investing consistently, even in small amounts'),(11,18,'The Power of a Positive Money Mindset','How does a positive money mindset influence financial success?','[{\"id\": 1, \"text\": \"It guarantees financial success without effort\"}, {\"id\": 2, \"text\": \"It helps individuals make intentional and confident financial decisions\"}, {\"id\": 3, \"text\": \"It removes the need for financial planning\"}, {\"id\": 4, \"text\": \"It encourages taking unnecessary financial risks\"}]','It helps individuals make intentional and confident financial decisions'),(12,17,'Principles of Wealth Building','What is a fundamental principle of building long-term wealth?','[{\"id\": 1, \"text\": \"Relying solely on a high-paying job\"}, {\"id\": 2, \"text\": \"Investing and generating multiple income streams\"}, {\"id\": 3, \"text\": \"Spending more than you earn and using credit\"}, {\"id\": 4, \"text\": \"Keeping all money in a savings account without investing\"}]','Investing and generating multiple income streams'),(13,16,'Strategies for Effective Saving','What is the best way to maximize savings over time?','[{\"id\": 1, \"text\": \"Saving only when there???s extra money left at the end of the month\"}, {\"id\": 2, \"text\": \"Setting up automatic savings and reducing unnecessary expenses\"}, {\"id\": 3, \"text\": \"Avoiding saving to focus on paying off debt\"}, {\"id\": 4, \"text\": \"Keeping all savings in cash at home\"}]','Setting up automatic savings and reducing unnecessary expenses'),(14,15,'Making Smart Spending Decisions','What is a key habit of smart spending?','[{\"id\": 1, \"text\": \"Buying items based on impulse\"}, {\"id\": 2, \"text\": \"Comparing prices and evaluating needs vs wants\"}, {\"id\": 3, \"text\": \"Spending without tracking expenses\"}, {\"id\": 4, \"text\": \"Purchasing luxury items before covering essentials\"}]','Comparing prices and evaluating needs vs wants'),(15,14,'Advanced Budgeting Techniques','What is an advanced budgeting technique to improve financial stability?','[{\"id\": 1, \"text\": \"Ignoring unexpected expenses\"}, {\"id\": 2, \"text\": \"Using the zero-based budgeting method to assign every dollar a purpose\"}, {\"id\": 3, \"text\": \"Only budgeting for fixed expenses and ignoring variable costs\"}, {\"id\": 4, \"text\": \"Setting unrealistic budget limits that are hard to maintain\"}]','Using the zero-based budgeting method to assign every dollar a purpose'),(16,10,'Understanding Advanced Cryptocurrency Concepts','What is the main purpose of a smart contract in blockchain technology?','[{\"id\": 1, \"text\": \"To execute automated agreements without intermediaries\"}, {\"id\": 2, \"text\": \"To store cryptocurrency in a secure way\"}, {\"id\": 3, \"text\": \"To mine new cryptocurrency tokens\"}, {\"id\": 4, \"text\": \"To convert cryptocurrencies into fiat currencies\"}]','To execute automated agreements without intermediaries'),(17,9,'Safely Handling Cryptocurrency Transactions','What is the safest way to store cryptocurrency for long-term security?','[{\"id\": 1, \"text\": \"Keeping it on an exchange platform\"}, {\"id\": 2, \"text\": \"Using a hardware wallet or cold storage\"}, {\"id\": 3, \"text\": \"Leaving it in a mobile wallet\"}, {\"id\": 4, \"text\": \"Storing it in a text document on your computer\"}]','Using a hardware wallet or cold storage'),(18,8,'Basics of Cryptocurrency','What is the primary function of cryptocurrency?','[{\"id\": 1, \"text\": \"To act as a decentralized digital currency\"}, {\"id\": 2, \"text\": \"To replace all traditional banking systems immediately\"}, {\"id\": 3, \"text\": \"To serve as a government-controlled financial tool\"}, {\"id\": 4, \"text\": \"To only be used for online shopping\"}]','To act as a decentralized digital currency'),(19,7,'Maximizing Returns with Advanced Real Estate Strategies','What is a common strategy used in real estate to generate passive income?','[{\"id\": 1, \"text\": \"House flipping for short-term profits\"}, {\"id\": 2, \"text\": \"Investing in rental properties for consistent cash flow\"}, {\"id\": 3, \"text\": \"Buying properties and leaving them vacant for years\"}, {\"id\": 4, \"text\": \"Purchasing land without any development plans\"}]','Investing in rental properties for consistent cash flow'),(20,5,'Understanding Real Estate Fundamentals','What is a key factor to consider before purchasing real estate?','[{\"id\": 1, \"text\": \"The current price without considering market trends\"}, {\"id\": 2, \"text\": \"The location and potential for property value appreciation\"}, {\"id\": 3, \"text\": \"Only the interior design of the property\"}, {\"id\": 4, \"text\": \"The number of bedrooms, regardless of market demand\"}]','The location and potential for property value appreciation'),(21,4,'Introduction to Investment Strategies','What is a fundamental principle of successful investing?','[{\"id\": 1, \"text\": \"Investing all your money in a single asset\"}, {\"id\": 2, \"text\": \"Diversifying investments to spread risk\"}, {\"id\": 3, \"text\": \"Only investing in high-risk stocks for quick returns\"}, {\"id\": 4, \"text\": \"Keeping all money in a savings account instead of investing\"}]','Diversifying investments to spread risk'),(22,3,'Basics of Credit Management','What is the most important factor in maintaining a good credit score?','[{\"id\": 1, \"text\": \"Maxing out your credit cards every month\"}, {\"id\": 2, \"text\": \"Making timely payments on credit obligations\"}, {\"id\": 3, \"text\": \"Opening multiple credit accounts at once\"}, {\"id\": 4, \"text\": \"Ignoring your credit report\"}]','Making timely payments on credit obligations'),(23,2,'Fundamentals of Budgeting','What is the primary goal of budgeting?','[{\"id\": 1, \"text\": \"To track and control expenses while planning for financial goals\"}, {\"id\": 2, \"text\": \"To spend money freely without limits\"}, {\"id\": 3, \"text\": \"To avoid saving money for future needs\"}, {\"id\": 4, \"text\": \"To only focus on fixed expenses and ignore variable costs\"}]','To track and control expenses while planning for financial goals');
