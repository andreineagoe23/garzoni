# Copy to `.env` for local dev (Expo loads EXPO_PUBLIC_* at bundle time).
# Use your machine IP for a physical device (not localhost).
#
# EAS builds: set the same vars for cloud builds, e.g.
#   eas secret:create --scope project --name EXPO_PUBLIC_BACKEND_URL --value https://monevo-production-bc08.up.railway.app/api
#   eas secret:create --scope project --name EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME --value com.googleusercontent.apps.YOUR_IOS_CLIENT_PREFIX
# Include /api if your Django API is mounted at /api (match packages/core backendUrl).

EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000/api

# Google Sign-In (native). Web client ID is required on Android for ID tokens.
# iOS OAuth client ID (Google Cloud Console → iOS client).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Reversed iOS client scheme for @react-native-google-signin (must match iOS OAuth client).
# Set in EAS to rotate without editing app.config.js. Optional locally if different from default in app.config.js.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
