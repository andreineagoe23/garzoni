# Copy to `.env` for local dev (Expo loads EXPO_PUBLIC_* at bundle time).
# Use your machine IP for a physical device (not localhost).
#
# EAS builds: set the same vars for cloud builds, e.g.
#   eas secret:create --scope project --name EXPO_PUBLIC_BACKEND_URL --value https://monevo-production-bc08.up.railway.app/api
#   eas secret:create --scope project --name EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME --value com.googleusercontent.apps.YOUR_IOS_CLIENT_PREFIX
# Include /api if your Django API is mounted at /api (match packages/core backendUrl).

EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000/api

# Google Sign-In (native). Web client ID is required on Android for ID tokens.
# iOS: use the iOS OAuth client ID from Cloud Console (not the web client).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Reversed iOS client ID (REVERSED_CLIENT_ID from the iOS client plist — must match iOS client, not web).
# Do not commit real values; set here locally and in EAS secrets. If you download a plist from Google,
# save it as GoogleSignIn.credentials.plist (gitignored) or paste REVERSED_CLIENT_ID into this var.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Sign in with Apple (iOS only in the app). Enable the capability in Apple Developer + EAS, then configure Django:
#   APPLE_SIGNIN_BUNDLE_ID=tech.monevo.app
# (must match app.json ios.bundleIdentifier) or use APPLE_SIGNIN_AUDIENCES_CSV for multiple audiences.
