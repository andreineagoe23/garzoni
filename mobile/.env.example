# Copy to `.env`, `.env.development.local`, or `.env.local` (gitignored).
# Restart Metro with `pnpm exec expo start --clear` after changes.
# Expo load order for local dev: .env.development.local → .env.development → .env.local → .env
#
# --- Environment (drives native HTTP allowances for Docker / LAN in app.config.js) ---
# `development` → iOS NSAllowsLocalNetworking + Android cleartext for http:// LAN/Docker.
# `production` → omit or set for store / EAS production builds (HTTPS API only).
EXPO_PUBLIC_APP_ENV=development

# Optional: force LAN HTTP allowances even if APP_ENV is not development.
# EXPO_PUBLIC_ALLOW_INSECURE_LOCAL_HTTP=1

# --- Django API (must end with /api or base host; @garzoni/core normalizes) ---
# iOS Simulator (Docker on same Mac):
# EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000/api
# Physical device on same Wi‑Fi as your Mac (Docker publishes port 8000):
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.XX:8000/api
# Android emulator → host machine:
# EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000/api
# Hosted API (production / staging):
# EXPO_PUBLIC_BACKEND_URL=https://your-api.example.com/api

# --- Web app (Tools / Legal WebViews) ---
# EXPO_PUBLIC_WEB_APP_URL=https://app.example.com

# --- Google Sign-In (same clients as backend / frontend) ---
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# --- Media ---
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- RevenueCat (public iOS key; use sandbox/test key when EXPO_PUBLIC_APP_ENV=development) ---
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# --- EAS Build (production) ---
# Set EXPO_PUBLIC_BACKEND_URL, Google keys, RevenueCat live key, etc. in Expo dashboard:
# Project → Environment variables (or eas secret:create). Do not commit production secrets.
# eas.json sets EXPO_PUBLIC_APP_ENV per profile (development/preview → development, production → production).
