# Non-secret defaults for local development. Override in `.env.development.local` (gitignored).
EXPO_PUBLIC_APP_ENV=development
# Keep mobile on the same local Docker-backed backend as web by default.
# iOS simulator: 127.0.0.1 works.
# Android emulator: override in `.env.development.local` with EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000/api
# Physical device: override with your Mac LAN IP, e.g. http://192.168.1.10:8000/api
EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000/api
EXPO_PUBLIC_WEB_APP_URL=https://www.garzoni.app
