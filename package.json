{
  "name": "garzoni",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend",
    "mobile"
  ],
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "react-vertical-timeline-component"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @garzoni/web dev",
    "dev:web": "pnpm --filter @garzoni/web dev",
    "dev:mobile": "pnpm --filter @garzoni/mobile start",
    "build": "pnpm --filter @garzoni/web build",
    "build:frontend": "pnpm --filter @garzoni/web build",
    "build:marketing": "cd frontend/next-app && npm run build",
    "build:all": "pnpm run build:frontend && pnpm run build:marketing",
    "test": "pnpm --filter @garzoni/web test",
    "lint": "pnpm --filter @garzoni/web lint",
    "typecheck:core": "pnpm --filter @garzoni/core typecheck",
    "typecheck:web": "pnpm --filter @garzoni/web exec tsc --noEmit",
    "typecheck:mobile": "pnpm --filter @garzoni/mobile exec tsc --noEmit",
    "typecheck": "pnpm run typecheck:core && pnpm run typecheck:web && pnpm run typecheck:mobile",
    "lint:mobile": "pnpm --filter @garzoni/mobile lint",
    "format:backend": "black backend/",
    "lint:backend": "black --check backend && flake8 backend",
    "qa:backend": "pnpm run lint:backend",
    "qa:mobile": "pnpm run typecheck:mobile && pnpm run lint:mobile && pnpm run test:core",
    "test:core": "pnpm --filter @garzoni/core test",
    "precommit": "pnpm run typecheck && pnpm lint && pnpm --filter @garzoni/web format:check",
    "upload:cloudinary": "node scripts/upload-cloudinary-images.js",
    "upload:cloudinary:dry-run": "node scripts/upload-cloudinary-images.js --dry-run"
  },
  "dependencies": {
    "cloudinary": "^2.9.0"
  }
}
